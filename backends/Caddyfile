# ─────────────────────────────────────────────────────────────
# Caddyfile — Job-Hub Backend
# Server IP : 43.205.126.40
# Frontend  : https://job-hubs.vercel.app
#
# NOTE: Caddy cannot obtain TLS certificates for bare IP addresses.
#       We run on plain HTTP (port 80).
#       The Node app itself handles all CORS — do NOT add CORS
#       headers here or they will be duplicated and break preflight.
# ─────────────────────────────────────────────────────────────

:80 {
    # ── Reverse proxy everything to the Node app ──────────────
    # Caddy automatically upgrades WebSocket connections
    # (Socket.IO polling + websocket transports both work)
    reverse_proxy app:3001 {
        # Pass the real client IP to the app
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}

        # Keep websocket connections alive
        transport http {
            keepalive 30s
            keepalive_idle_conns 10
        }
    }

    # ── Compression ───────────────────────────────────────────
    encode gzip zstd

    # ── Access log ────────────────────────────────────────────
    log {
        output file /var/log/caddy/access.log {
            roll_size     50mb
            roll_keep     5
            roll_keep_for 720h
        }
        format json
    }
}
