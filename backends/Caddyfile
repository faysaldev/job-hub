# Caddyfile configuration for Job-Hub Backend
# Replace your-domain.com with your actual domain or subdomain

#let's increate certificates
api.your-domain.com {
    # Reverse proxy all requests (including websockets/socket.io) to the Node app
    reverse_proxy app:3001

    # Enable compression
    encode gzip zstd

    # Optional: Log configurations
    log {
        output file /var/log/caddy/api_access.log
    }
}
